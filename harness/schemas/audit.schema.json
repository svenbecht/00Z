{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://00z.local/schemas/audit.schema.json",
  "title": "00Z audit event schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "run_id", "actor", "event_type", "target_paths", "risk_level", "trust_zone", "decision", "result", "redacted"],
  "properties": {
    "timestamp": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "event_type": {"type": "string", "enum": ["pipeline_run", "tool_call", "gate_decision", "hitl_confirmation", "policy_block"]},
    "target_paths": {"type": "array", "items": {"type": "string"}},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "trust_zone": {"type": "string", "minLength": 1},
    "decision": {"type": "string", "minLength": 1},
    "result": {"type": "string", "minLength": 1},
    "redacted": {"type": "boolean", "const": true},
    "user_confirmation_id": {"type": "string"}
  }
}
