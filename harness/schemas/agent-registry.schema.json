{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://00z.local/schemas/agent-registry.schema.json",
  "title": "00Z agent registry schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "purpose", "defaults", "agents"],
  "properties": {
    "version": { "type": "string" },
    "updated": { "type": "string" },
    "purpose": { "type": "string" },
    "defaults": {
      "type": "object",
      "properties": {
        "language": { "type": "string" },
        "evidence_required": { "type": "boolean" },
        "reveal_chain_of_thought": { "const": false },
        "allowed_tools_default": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "file", "type", "allowed_tools", "triggers", "reasoning_profile"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "name": { "type": "string" },
          "file": { "$ref": "#/$defs/path" },
          "type": { "type": "string", "enum": ["orchestrator", "reactive", "proactive", "hybrid", "validator"] },
          "context_profile": { "type": "string" },
          "allowed_tools": { "type": "array", "items": { "type": "string" } },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "max_tokens": { "type": "integer", "minimum": 1 },
          "reasoning_profile": { "type": "string" },
          "reasoning_methods": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "$defs": {
    "path": { "type": "string", "minLength": 1, "not": { "pattern": "(^/|\\.\\.)" } }
  }
}
