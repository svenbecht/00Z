{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://00z.local/schemas/pipeline.schema.json",
  "title": "00Z pipeline schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "version", "status", "trigger", "purpose", "constraints", "steps"],
  "properties": {
    "id": { "type": "string", "enum": ["p1", "p2", "p3"] },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "status": { "type": "string", "enum": ["scaffold", "draft", "active", "stable", "deprecated"] },
    "trigger": { "type": "string", "pattern": "^ZEN P[123]$" },
    "state_transition": { "type": "string" },
    "purpose": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "object",
      "required": ["max_agents", "force_gate"],
      "properties": {
        "max_agents": { "type": "integer", "minimum": 1, "maximum": 3 },
        "max_rework_cycles": { "type": "integer", "minimum": 0, "maximum": 2 },
        "force_gate": { "type": "boolean" },
        "security_gates": { "type": "array", "items": { "type": "string" } }
      }
    },
    "routing": { "type": "object" },
    "inputs": { "type": "object" },
    "artifacts": { "type": "object" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "actor": { "type": "string" },
          "agent": { "$ref": "#/$defs/path" },
          "action": { "type": "string" },
          "output": { "type": "string" },
          "required": { "type": "boolean" },
          "max_agents": { "type": "integer", "minimum": 1, "maximum": 3 }
        }
      }
    },
    "gate_semantics": { "type": "object" },
    "artifact_policy": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "id": { "const": "p3" } } },
      "then": {
        "properties": {
          "constraints": {
            "properties": {
              "force_gate": { "const": true },
              "max_agents": { "maximum": 3 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "path": { "type": "string", "minLength": 1, "not": { "pattern": "(^/|\\.\\.)" } }
  }
}
