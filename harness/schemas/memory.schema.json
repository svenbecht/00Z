{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://00z.local/schemas/memory.schema.json",
  "title": "00Z memory frontmatter schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["type"],
  "properties": {
    "type": { "type": "string", "pattern": "^memory(_hot|_cold)?$" },
    "layer": { "type": "string" },
    "status": { "type": "string", "enum": ["scaffold", "draft", "active", "stable", "archived"] },
    "priority": { "type": "integer", "minimum": 0 },
    "max_tokens": { "type": "integer", "minimum": 1 },
    "updated": { "type": "string" },
    "project": { "type": "string" },
    "projects": { "type": ["array", "string"], "items": { "type": "string" } }
  }
}
